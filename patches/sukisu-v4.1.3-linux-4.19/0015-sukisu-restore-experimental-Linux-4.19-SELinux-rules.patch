+static int sepol_require_explicit_allow(const char **args, size_t count)
+{
+    size_t i;
+
+    for (i = 0; i < count; i++) {
+        if (args[i] != ALL)
+            continue;
+
+        pr_err("SukiSU-4.19: dynamic sepolicy rejected wildcard allow argument #%zu\n", i);
