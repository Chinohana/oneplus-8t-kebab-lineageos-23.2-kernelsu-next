From ce4499df301a84b1c8fb2ded87bd74c4521b8fa5 Mon Sep 17 00:00:00 2001
From: Chinohana <chinohana@outlook.com>
Date: Wed, 22 Jul 2026 04:53:09 +0800
Subject: [PATCH] security: disable unsafe SELinux policy mutation on Linux
 4.19

Do not modify selinux_state.ss->policydb without its real policy_rwlock. Boot rule application emits an explicit warning, dynamic handle_sepolicy returns -EOPNOTSUPP, and legacy policy helpers are not compiled until the stage 3 locking design is implemented.
---
 kernel/selinux/rules.c    | 18 ++++++++++++++++++
 kernel/selinux/sepolicy.c |  7 ++++++-
 2 files changed, 24 insertions(+), 1 deletion(-)

diff --git a/kernel/selinux/rules.c b/kernel/selinux/rules.c
index 98fc276c..e3ecba0d 100644
--- a/kernel/selinux/rules.c
+++ b/kernel/selinux/rules.c
@@ -15,6 +15,22 @@
 #include "linux/lsm_audit.h" // IWYU pragma: keep
 #include "xfrm.h"
 
+#if LINUX_VERSION_CODE < KERNEL_VERSION(5, 10, 0)
+
+void apply_kernelsu_rules(void)
+{
+    pr_warn_once("KernelSU SELinux policy mutation is unsupported on this kernel\n");
+}
+
+int handle_sepolicy(void __user *user_data, u64 data_len)
+{
+    (void)user_data;
+    (void)data_len;
+    return -EOPNOTSUPP;
+}
+
+#else
+
 #if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
 struct selinux_policy *backup_sepolicy;
 #define SELINUX_POLICY_INSTEAD_SELINUX_SS
@@ -559,3 +575,5 @@ out_free:
 
     return ret;
 }
+
+#endif /* Linux 5.10+ transactional policy implementation */
diff --git a/kernel/selinux/sepolicy.c b/kernel/selinux/sepolicy.c
index da8d005f..7e756e06 100644
--- a/kernel/selinux/sepolicy.c
+++ b/kernel/selinux/sepolicy.c
@@ -1,3 +1,7 @@
+#include <linux/version.h>
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 10, 0)
+
 #include "ss/avtab.h"
 #include "ss/constraint.h"
 #include "ss/ebitmap.h"
@@ -7,7 +11,6 @@
 #include <linux/gfp.h>
 #include <linux/printk.h>
 #include <linux/slab.h>
-#include <linux/version.h>
 #include <linux/vmalloc.h>
 
 #include "sepolicy.h"
@@ -948,3 +951,5 @@ out_free_data:
     return ERR_PTR(ret);
 }
 #endif
+
+#endif /* Linux 5.10+ SELinux policy helpers */
-- 
2.53.0.windows.2

